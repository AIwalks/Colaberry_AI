# ============================================================
# Colaberry AI — environment variable reference
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ------------------------------------------------------------
# API authentication
# FastAPI layer: all endpoints require this key in X-Api-Key header.
# Must not be empty when the server starts.
# ------------------------------------------------------------
API_KEY=your-api-key-here

# ------------------------------------------------------------
# Anthropic / Claude SDK
# Used by services/ai_insight_service.py to call Claude.
# Distinct from API_KEY — do not conflate.
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# MSSQL database — option A: full connection DSN
# Takes precedence over the individual vars below if set.
# Example driver string: ODBC+Driver+17+for+SQL+Server
# ------------------------------------------------------------
# MSSQL_DATABASE_URL=mssql+pyodbc://<USERNAME>:<PASSWORD>@<SERVER>/<DATABASE>?driver=ODBC+Driver+17+for+SQL+Server  # pragma: allowlist secret

# ------------------------------------------------------------
# MSSQL database — option B: individual env vars
# Used to build the DSN when MSSQL_DATABASE_URL is not set.
# All four of SERVER, DATABASE, USERNAME, PASSWORD must be
# provided; DRIVER defaults to "ODBC Driver 17 for SQL Server".
# ------------------------------------------------------------
MSSQL_SERVER=your-sql-server.database.windows.net
MSSQL_DATABASE=your-database-name
MSSQL_USERNAME=your-db-username
MSSQL_PASSWORD=your-db-password
MSSQL_DRIVER=ODBC Driver 17 for SQL Server

# Set to "true" once the above MSSQL vars are correctly wired.
# When false (default), the app uses a local SQLite fallback.
MSSQL_CONFIGURED=false

# ------------------------------------------------------------
# Sentinel shadow-mode
# SENTINEL_SHADOW_MODE — opt-in flag to enable shadow-mode reads.
#   Set to "true" to activate shadow-mode operation.
#   When false, Sentinel serves mock data regardless of DB state.
#
# SENTINEL_LIVE is derived automatically:
#   SENTINEL_LIVE = MSSQL_CONFIGURED=true AND SENTINEL_SHADOW_MODE=true
#   You do not set SENTINEL_LIVE directly.
# ------------------------------------------------------------
SENTINEL_SHADOW_MODE=false

# ------------------------------------------------------------
# Twilio — outbound delivery and inbound webhook
# Required for real SMS/WhatsApp delivery and to receive replies.
# All four vars below must be set; otherwise delivery is skipped
# and the inbound webhook returns 503.
#
# TWILIO_FROM_NUMBER  — the Twilio phone number used as the sender
#                       (E.164 format, e.g. +14155238886).
# OUTBOUND_USE_WHATSAPP — set to "1" to send via WhatsApp channel;
#                         omit or set to "0" for plain SMS.
# OUTBOUND_TEST_PHONE   — dev/staging only: override recipient phone
#                         so all messages go to a single test number.
# ------------------------------------------------------------
TWILIO_ACCOUNT_SID=replace_with_twilio_account_sid
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
TWILIO_FROM_NUMBER=replace_with_twilio_from_number
OUTBOUND_USE_WHATSAPP=0
OUTBOUND_TEST_PHONE=replace_with_test_phone_number
